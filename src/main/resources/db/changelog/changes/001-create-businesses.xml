<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="001-create-businesses" author="codex">
        <createTable tableName="businesses">
            <column name="id" type="uuid">
                <constraints primaryKey="true" primaryKeyName="pk_businesses" nullable="false"/>
            </column>
            <column name="name" type="varchar(160)">
                <constraints nullable="false"/>
            </column>
            <column name="slug" type="varchar(120)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(2000)"/>
            <column name="phone" type="varchar(50)"/>
            <column name="email" type="varchar(255)"/>
            <column name="website_url" type="varchar(2048)"/>
            <column name="address" type="varchar(255)"/>
            <column name="city" type="varchar(120)"/>
            <column name="status" type="varchar(32)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="businesses" columnNames="slug" constraintName="uk_businesses_slug"/>
        <createIndex tableName="businesses" indexName="idx_businesses_status">
            <column name="status"/>
        </createIndex>
        <sql dbms="postgresql,h2">ALTER TABLE businesses ADD CONSTRAINT chk_businesses_status CHECK (status IN ('ACTIVE', 'INACTIVE'))</sql>
    </changeSet>
</databaseChangeLog>
