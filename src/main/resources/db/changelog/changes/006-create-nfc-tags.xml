<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="006-create-nfc-tags" author="codex">
        <createTable tableName="nfc_tags">
            <column name="id" type="uuid">
                <constraints primaryKey="true" primaryKeyName="pk_nfc_tags" nullable="false"/>
            </column>
            <column name="business_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_nfc_tags_business"
                             referencedTableName="business" referencedColumnNames="id"/>
            </column>
            <column name="tag_code" type="varchar(150)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_nfc_tags_tag_code"/>
            </column>
            <column name="location_name" type="varchar(150)"/>
            <column name="status" type="varchar(32)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="last_used_at" type="timestamp with time zone"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="nfc_tags" indexName="idx_nfc_tags_business_status">
            <column name="business_id"/>
            <column name="status"/>
        </createIndex>
        <sql dbms="postgresql,h2">ALTER TABLE nfc_tags ADD CONSTRAINT chk_nfc_tags_status CHECK (status IN ('ACTIVE', 'DISABLED', 'LOST', 'REPLACED'))</sql>
    </changeSet>
</databaseChangeLog>
