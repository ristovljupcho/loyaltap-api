<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="007-create-stamp-requests" author="codex">
        <createTable tableName="stamp_requests">
            <column name="id" type="uuid">
                <constraints primaryKey="true" primaryKeyName="pk_stamp_requests" nullable="false"/>
            </column>
            <column name="membership_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_stamp_requests_membership"
                             referencedTableName="memberships" referencedColumnNames="id"/>
            </column>
            <column name="business_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_stamp_requests_business"
                             referencedTableName="business" referencedColumnNames="id"/>
            </column>
            <column name="nfc_tag_id" type="uuid">
                <constraints foreignKeyName="fk_stamp_requests_nfc_tag"
                             referencedTableName="nfc_tags" referencedColumnNames="id"/>
            </column>
            <column name="approved_by_employee_id" type="uuid">
                <constraints foreignKeyName="fk_stamp_requests_employee"
                             referencedTableName="employee" referencedColumnNames="id"/>
            </column>
            <column name="points_to_add" type="integer" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(32)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="idempotency_key" type="varchar(150)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_stamp_requests_idempotency_key"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="processed_at" type="timestamp with time zone"/>
        </createTable>
        <createIndex tableName="stamp_requests" indexName="idx_stamp_requests_business_status_created">
            <column name="business_id"/>
            <column name="status"/>
            <column name="created_at"/>
        </createIndex>
        <createIndex tableName="stamp_requests" indexName="idx_stamp_requests_status_expires">
            <column name="status"/>
            <column name="expires_at"/>
        </createIndex>
        <sql dbms="postgresql,h2">ALTER TABLE stamp_requests ADD CONSTRAINT chk_stamp_requests_points CHECK (points_to_add > 0)</sql>
        <sql dbms="postgresql,h2">ALTER TABLE stamp_requests ADD CONSTRAINT chk_stamp_requests_status CHECK (status IN ('PENDING', 'APPROVED', 'REJECTED', 'EXPIRED', 'CANCELLED'))</sql>
    </changeSet>
</databaseChangeLog>
